# Copy to .env and fill in. Never commit .env.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Server ---
PORT=5174
HOST=127.0.0.1
NODE_ENV=development

# --- Data location ---
# Leave blank to use ~/.powerh/powerh.sqlite
POWERH_DATA_DIR=

# --- Strava (configured at runtime through the UI, but you can pre-fill) ---
# Create your own Strava API app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Agent ---
ANTHROPIC_MODEL=claude-opus-4-7
# Cheaper option for chitchat:
# ANTHROPIC_MODEL=claude-sonnet-4-6
